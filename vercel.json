{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "regions": ["icn1"],
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{tests/**,__tests__/**,.git/**,.pytest_cache/**,.venv/**,assets/**,static/**}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}

